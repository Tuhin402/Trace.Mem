APP_NAME=TraceMem
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# ── Domain configuration ───────────────────────────────────────────────────────
# Production:  APP_URL=https://tracemem.one
#              APP_DOMAIN=tracemem.one
#              APP_APP_DOMAIN=app.tracemem.one
#              APP_API_DOMAIN=api.tracemem.one
#
# Local dev:   Leave APP_URL=http://localhost (or http://localhost:8000).
#              The APP_*_DOMAIN values below are still needed for CORS config and
#              frontend constants even in local — they don't affect routing.
APP_DOMAIN=tracemem.one
APP_APP_DOMAIN=app.tracemem.one
APP_API_DOMAIN=api.tracemem.one

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database ──────────────────────────────────────────────────────────────────
# Local development: use SQLite (zero setup)
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=tracemem
# DB_USERNAME=root
# DB_PASSWORD=

# ── Sessions ──────────────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Production: set these to harden session cookies
# SESSION_SECURE_COOKIE=true      ← HTTPS-only; MUST be true in production
# SESSION_HTTP_ONLY=true          ← prevents JS access to the session cookie
# SESSION_SAME_SITE=lax           ← protects against CSRF; lax is the safe default

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ── Queue ─────────────────────────────────────────────────────────────────────
# Production: use redis (requires Redis running + queue worker)
# Local dev: 'database' or 'sync' works without Redis
QUEUE_CONNECTION=redis
# QUEUE_CONNECTION=database
# QUEUE_CONNECTION=sync

# Production queue worker command (run via Supervisor in production):
#   php artisan queue:work redis --queue=high,default,low --sleep=3 --tries=3 --max-time=3600
#
# Local dev (handled automatically by composer run dev):
#   php artisan queue:work redis --queue=high,default,low
#
# Queue priority levels:
#   high    → ProcessStripeWebhookJob (billing-critical)
#   default → AggregateUsageStatsJob, notifications
#   low     → ReinforceMemoriesJob, DecayMemoryJob, DecayMemoriesSweepJob

# ── Cache ─────────────────────────────────────────────────────────────────────
# Production: use redis for tagging support (required by TraceMemCache)
# Local dev without Redis: 'file' works correctly (TraceMemCache handles fallback)
CACHE_STORE=redis
# CACHE_STORE=file
# CACHE_STORE=database
# CACHE_PREFIX=

# ── Redis ─────────────────────────────────────────────────────────────────────
# phpredis extension is recommended (faster than predis)
# Install: pecl install redis (or via your package manager)
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Production: use separate Redis instances for cache vs queues to prevent
# cache eviction (allkeys-lru) from deleting queued jobs.
# Uncomment and configure dedicated connections:
# REDIS_CACHE_HOST=127.0.0.1
# REDIS_CACHE_PORT=6379
# REDIS_CACHE_PASSWORD=null
# REDIS_QUEUE_HOST=127.0.0.1
# REDIS_QUEUE_PORT=6380
# REDIS_QUEUE_PASSWORD=null

# ── Mail ──────────────────────────────────────────────────────────────────────
# 'log' driver: emails are written to the Laravel log file (good for local dev)
# Production: use smtp, mailgun, ses, postmark, etc.
MAIL_MAILER=log
# MAIL_MAILER=smtp
# MAIL_SCHEME=null
# MAIL_HOST=smtp.mailgun.org
# MAIL_PORT=587
# MAIL_USERNAME=null
# MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@tracemem.one"
MAIL_FROM_NAME="TraceMem"

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_KEY=pk_test_YOUR_PUBLISHABLE_KEY_HERE
STRIPE_SECRET=sk_test_YOUR_SECRET_KEY_HERE
# Webhook secret — generate via: stripe listen --forward-to localhost:8000/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# ── AI / LLM ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-YOUR_OPENAI_KEY_HERE
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# NVIDIA NIM (optional alternative to OpenAI)
# NVIDIA_KEY=nvapi-YOUR_NVIDIA_KEY_HERE
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# ── AWS (optional) ────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Frontend / Vite ───────────────────────────────────────────────────────────
VITE_APP_NAME=TraceMem
VITE_APP_SLUG=tracemem
MEMCACHED_HOST=127.0.0.1

# ── Database Backups ──────────────────────────────────────────────────────────
# backup:database runs daily at 02:00 via the Laravel scheduler.
# For managed databases (RDS, Supabase, Neon, PlanetScale), set:
#   BACKUP_DRIVER=managed
# ...and rely on your provider's native backup system instead.
#
# BACKUP_DIR=/var/backups/tracemem          # absolute path to store backups
# BACKUP_RETENTION_DAYS=30                  # delete backups older than N days
# BACKUP_DRIVER=                            # override: sqlite|pgsql|mysql|managed (auto-detected if blank)
